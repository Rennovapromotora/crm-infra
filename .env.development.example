# Copie para .env na raiz do crm-infra:
#   cp .env.development.example .env
#
# Subir:
#   docker compose --env-file .env up -d --build

# Caminhos para os clones (Windows ou Linux — ajuste se necessário)
CRM_API_PATH=../crm-api
CRM_WEB_PATH=../crm-rennova

# Portas expostas no host
API_HTTP_PORT=8000
WEB_HTTP_PORT=8082
MYSQL_PUBLISH_PORT=3306
REDIS_PUBLISH_PORT=6379
#
# Se você já tem MySQL rodando na máquina, use 3307 para evitar conflito:
# MYSQL_PUBLISH_PORT=3307

# ── Maria de dados dev (troque em time compartilhado) ──
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=crm_rennova
MYSQL_USER=crm
MYSQL_PASSWORD=crm

# Redis sem senha no container dev — use string "null" como no projeto crm-api
REDIS_PASSWORD=null

# ── Laravel (URLs que o navegador usa) ──
APP_KEY=
# Se APP_KEY vazio, o entrypoint gera uma (não recomendado repetir builds sem volume)
API_APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8082
TRUST_PROXY=false

REACT_APP_API_URL=http://localhost:8000/api

# Opcional Facta homologação (já é o default no compose dev)
# FACTA_API_URL=https://webservice-homol.facta.com.br
# FACTA_API_USERNAME=
# FACTA_API_PASSWORD=
