# Produção — copie e preencha:
#   cp .env.prod.example .env.prod
#
# docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build

CRM_API_PATH=../crm-api
CRM_WEB_PATH=../crm-rennova

EDGE_HTTP_PORT=80
EDGE_HTTPS_PORT=443

# MySQL
MYSQL_ROOT_PASSWORD=troque_uma_senha_forte
MYSQL_DATABASE=crm_rennova
MYSQL_USER=crm
MYSQL_PASSWORD=troque_outra_senha_forte

# Redis (obrigatório em prod neste compose)
REDIS_PASSWORD=troque_redis_forte

# Laravel
APP_KEY=base64:TROCAR_com_php_artisan_key_generate
API_APP_URL=https://api.rennovafgts.com.br
FRONTEND_URL=https://crm.rennovafgts.com.br
SANCTUM_STATEFUL_DOMAINS=crm.rennovafgts.com.br

# Front: URL pública da API (termina em /api — usada no build do React)
REACT_APP_API_URL=https://api.rennovafgts.com.br/api

# E-mail (obrigatório no compose prod — use seu SMTP)
MAIL_MAILER=smtp
MAIL_HOST=smtp.seuprovedor.com
MAIL_PORT=587
MAIL_USERNAME=troque_smtp_user
MAIL_PASSWORD=troque_smtp_senha
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@rennova.com.br
MAIL_FROM_NAME=CRM Rennova

# Facta produção
FACTA_API_USERNAME=troque_usuario_facta
FACTA_API_PASSWORD=troque_senha_facta

# Opcional — chave no bundle do front (cuidado: visível no browser)
REACT_APP_API_KEY=
REACT_APP_API_KEY_HEADER=X-API-KEY
REACT_APP_ZAPI_INSTANCE_ID=
REACT_APP_ZAPI_ACCESS_TOKEN=
REACT_APP_ZAPI_CLIENT_TOKEN=
